{
  "name": "selectra-ai-ui",
  "productName": "Selectra AI",
  "version": "0.1.0",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "build:backend:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ../backend/scripts/build-backend-win.ps1",
    "dist:win": "npm run build:backend:win && electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ai.selectra.desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/selectra-backend.exe",
        "to": "backend/selectra-backend.exe"
      },
      {
        "from": "../backend/app",
        "to": "backend/app"
      },
      {
        "from": "../backend/requirements.txt",
        "to": "backend/requirements.txt"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
